# Service-to-service auth (must match finance-api REPORTS_AI_INTERNAL_TOKEN)
INTERNAL_TOKEN=change-this-internal-token

# NL -> SQL provider: mock | gemini | openrouter
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
LLM_TIMEOUT_SECONDS=20

# Speech-to-text provider: mock | groq
STT_PROVIDER=mock
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3
STT_TIMEOUT_SECONDS=30

# Audio limits
AUDIO_MAX_BYTES=10485760
