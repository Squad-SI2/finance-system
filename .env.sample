# App
APP_NAME=finance-system
APP_ENV=development
SPRING_PROFILES_ACTIVE=dev
BACKEND_PORT=8080

# Spring datasource
DB_HOST=serv-finance-db
DB_HOST_PORT=55432

DB_NAME=finance_db
DB_PORT=5432
DB_USER=finance_user
DB_PASSWORD=finance_password

# Backup CLI tools and storage
BACKUP_LOCAL_PATH=/storage/backups
PG_DUMP_PATH=pg_dump
PG_RESTORE_PATH=pg_restore
PSQL_PATH=psql

# JWT
JWT_SECRET=change-this-secret-key-with-at-least-32-characters
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Multitenancy
TENANT_HEADER_NAME=X-Tenant-Slug
PUBLIC_SCHEMA=public

# Seed Database 
APP_BOOTSTRAP_SAMPLE_DATA_ENABLED=False

# Reporting read-only roles (created by Flyway migration public/V9)
REPORTING_SCHEMA=reporting
TENANT_READONLY_DB_USER=finance_tenant_readonly
TENANT_READONLY_DB_PASSWORD=tenant_ro_pass
PLATFORM_READONLY_DB_USER=finance_platform_readonly
PLATFORM_READONLY_DB_PASSWORD=platform_ro_pass

# Reporting module (Fase 4). AI mode: mock (local) | http (reports-ai microservice)
REPORTS_AI_MODE=mock
REPORTS_AI_BASE_URL=http://reports-ai:8000
REPORTS_AI_INTERNAL_TOKEN=change-this-internal-token
REPORT_EXPORT_STORAGE_PATH=/app/generated-reports

# reports-ai microservice (Fase 3). LLM: mock|gemini|openrouter · STT: mock|groq
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
STT_PROVIDER=mock
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3

# CORS
CORS_ALLOWED_ORIGINS=https://sebaces.fyi,https://localhost:443,http://localhost:443,http://localhost:80,http://localhost,http://localhost:4200,http://localhost:8080,http://localhost:5200

# Frontend
FRONTEND_PORT=4200
API_BASE_URL=http://localhost:8080

# Inicial superadmin
PLATFORM_SUPERADMIN_EMAIL=superadmin@finance.local
PLATFORM_SUPERADMIN_PASSWORD=SuperAdmin123!
PLATFORM_SUPERADMIN_FIRST_NAME=Platform
PLATFORM_SUPERADMIN_LAST_NAME=Admin

# Mail
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@finance.local
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false

# Password reset
PASSWORD_RESET_EXPIRATION_MINUTES=30
PASSWORD_RESET_URL_BASE=http://localhost:4200/reset-password

# Notification config
NOTIFICATIONS_PUSH_ENABLED=true
NOTIFICATIONS_PROVIDER=FIREBASE
FIREBASE_CREDENTIALS_PATH=classpath:firebase/service-account.example.json
FIREBASE_PROJECT_ID=finance-system-29d3d

# Face++ (Face recognition)
FACEPP_API_KEY=
FACEPP_API_SECRET=

# Tamaño maximo de archivos (fotos)
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=2MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# OCR Space (Optical Character Recognition)
OCRSPACE_API_KEY=

# Stripe billing
STRIPE_SECRET_KEY=sk_test_51RcaQkEI7XEzyewpl1Z0lpdBUqi89S...***
STRIPE_PUBLIC_KEY=pk_test_51RcaQkEI7XEzyewp40mv9kPf2cIdrV...***
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:4200/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:4200/billing/cancel
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:4200/settings/billing
STRIPE_DEFAULT_CURRENCY=USD
BASIC_MONTHLY_AMOUNT=9.99
BASIC_YEARLY_AMOUNT=99.99
PRO_MONTHLY_AMOUNT=19.99
PRO_YEARLY_AMOUNT=199.99
