{
  "name": "finance-api-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "forwardPorts": [8080],

  "runArgs": [
    "--network=finance-system_finance-net",
    "--env-file=../.env.sample"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack"
      ]
    }
  },

  "remoteUser": "vscode"
}