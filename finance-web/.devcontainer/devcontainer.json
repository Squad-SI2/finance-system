{
  "name": "finance-web-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/finance-web",
  "mounts": [
    "source=${localWorkspaceFolder},target=/finance-web,type=bind,consistency=cached"
  ],
  "forwardPorts": [4200],
  "runArgs": [
    "--network=finance-system_finance-net",
    "--env-file=../.env.sample",
    "--hostname=thunder"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit",
          "source.organizeImports": "explicit"
        }
      }
    }
  },
  "postCreateCommand": "npm install",
  "remoteUser": "root"
}